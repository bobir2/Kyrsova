<UserControl x:Class="Kursova.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="➕ Додати" Command="{Binding AddCommand}" />
            <Button Content="✏ Редагувати" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButtonStyle}" />
            <Button Content="🗑 Видалити" Command="{Binding DeleteCommand}" Background="{StaticResource DangerBrush}" />
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="40" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*" />
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                <DataGridTextColumn Header="Адреса" Binding="{Binding Address}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
