<Window x:Class="Kursova.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Продукт"
        Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Назва *" />
            <TextBox x:Name="NameBox" />

            <TextBlock Text="Категорія *" Margin="0,8,0,0" />
            <ComboBox x:Name="CategoryBox" DisplayMemberPath="Name" />

            <TextBlock Text="Постачальник" Margin="0,8,0,0" />
            <ComboBox x:Name="SupplierBox" DisplayMemberPath="Name" />

            <TextBlock Text="Штрих-код" Margin="0,8,0,0" />
            <TextBox x:Name="BarcodeBox" />

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Одиниця виміру" />
                    <ComboBox x:Name="UnitBox" IsEditable="True" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Термін придатності" />
                    <DatePicker x:Name="ExpiryPicker" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Ціна закупівлі" />
                    <TextBox x:Name="PurchaseBox" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ціна продажу" />
                    <TextBox x:Name="SaleBox" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Кількість на складі" />
                    <TextBox x:Name="QuantityBox" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Мін. залишок" />
                    <TextBox x:Name="MinStockBox" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Скасувати" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}" Width="100" />
            <Button Content="Зберегти" Click="Save_Click" Width="100" />
        </StackPanel>
    </Grid>
</Window>
