<UserControl x:Class="Kursova.Views.StockMovementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="📥 Надходження" Command="{Binding AddIncomingCommand}" />
            <Button Content="📤 Відвантаження" Command="{Binding AddOutgoingCommand}" Background="{StaticResource AccentBrush}" />
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="40" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Movements}" SelectedItem="{Binding SelectedMovement}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="130" />
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="2*" />
                <DataGridTextColumn Header="Тип" Binding="{Binding MovementTypeDisplay}" Width="120" />
                <DataGridTextColumn Header="Кількість" Binding="{Binding Quantity}" Width="90" />
                <DataGridTextColumn Header="Ціна" Binding="{Binding UnitPrice, Converter={StaticResource Currency}}" Width="100" />
                <DataGridTextColumn Header="Примітка" Binding="{Binding Note}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
