<UserControl x:Class="Kursova.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <WrapPanel Margin="0,0,0,20">
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,16,16" Width="180"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Продуктів" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Stats.TotalProducts}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,16,16" Width="180"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Категорій" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Stats.TotalCategories}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,16,16" Width="180"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Постачальників" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Stats.TotalSuppliers}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,16,16" Width="220"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Вартість залишків" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Stats.TotalStockValue, Converter={StaticResource Currency}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="#FFF3E0" CornerRadius="8" Padding="20" Margin="0,0,16,16" Width="180"
                        BorderBrush="#FFE0B2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Низький залишок" Foreground="{StaticResource WarningBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Stats.LowStockCount}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="#FFEBEE" CornerRadius="8" Padding="20" Margin="0,0,16,16" Width="180"
                        BorderBrush="#FFCDD2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Прострочені" Foreground="{StaticResource DangerBrush}" FontSize="13" />
                        <TextBlock Text="{Binding Stats.ExpiredCount}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,12,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="⚠ Низький залишок" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <DataGrid ItemsSource="{Binding LowStockProducts}" Height="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Залишок" Binding="{Binding Quantity}" Width="80" />
                                <DataGridTextColumn Header="Мін." Binding="{Binding MinStockLevel}" Width="60" />
                                <DataGridTextColumn Header="Од." Binding="{Binding Unit}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="12,0,0,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📅 Термін придатності" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <DataGrid ItemsSource="{Binding ExpiringProducts}" Height="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Термін" Binding="{Binding ExpiryDate, Converter={StaticResource DateFormat}}" Width="100" />
                                <DataGridTextColumn Header="Залишок" Binding="{Binding Quantity}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Button Content="🔄 Оновити" Command="{Binding RefreshCommand}" HorizontalAlignment="Left" Margin="0,16,0,0" Width="120" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
