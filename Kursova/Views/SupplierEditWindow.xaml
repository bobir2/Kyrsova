<Window x:Class="Kursova.Views.SupplierEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Постачальник"
        Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Назва *" />
            <TextBox x:Name="NameBox" />
            <TextBlock Text="Телефон" Margin="0,8,0,0" />
            <TextBox x:Name="PhoneBox" />
            <TextBlock Text="Email" Margin="0,8,0,0" />
            <TextBox x:Name="EmailBox" />
            <TextBlock Text="Адреса" Margin="0,8,0,0" />
            <TextBox x:Name="AddressBox" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Скасувати" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}" Width="100" />
            <Button Content="Зберегти" Click="Save_Click" Width="100" />
        </StackPanel>
    </Grid>
</Window>
