<UserControl x:Class="Kursova.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Пошук за назвою або штрих-кодом..." />
            <ComboBox Width="200" Margin="8,4,0,4"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategoryFilter}"
                      DisplayMemberPath="Name" />
            <Button Content="➕ Додати" Command="{Binding AddCommand}" Margin="16,4,0,4" />
            <Button Content="✏ Редагувати" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButtonStyle}" />
            <Button Content="🗑 Видалити" Command="{Binding DeleteCommand}" Background="{StaticResource DangerBrush}" />
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="40" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Категорія" Binding="{Binding CategoryName}" Width="*" />
                <DataGridTextColumn Header="Постачальник" Binding="{Binding SupplierName}" Width="*" />
                <DataGridTextColumn Header="Штрих-код" Binding="{Binding Barcode}" Width="110" />
                <DataGridTextColumn Header="К-сть" Binding="{Binding Quantity}" Width="70" />
                <DataGridTextColumn Header="Од." Binding="{Binding Unit}" Width="50" />
                <DataGridTextColumn Header="Закупівля" Binding="{Binding PurchasePrice, Converter={StaticResource Currency}}" Width="100" />
                <DataGridTextColumn Header="Продаж" Binding="{Binding SalePrice, Converter={StaticResource Currency}}" Width="100" />
                <DataGridTextColumn Header="Термін" Binding="{Binding ExpiryDate, Converter={StaticResource DateFormat}}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
