<Window x:Class="Kursova.Views.StockMovementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Рух товару"
        Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TypeLabel" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
            <TextBlock Text="Продукт *" />
            <ComboBox x:Name="ProductBox" DisplayMemberPath="Name" />
            <TextBlock Text="Кількість *" Margin="0,8,0,0" />
            <TextBox x:Name="QuantityBox" />
            <TextBlock Text="Ціна за одиницю" Margin="0,8,0,0" />
            <TextBox x:Name="PriceBox" />
            <TextBlock Text="Примітка" Margin="0,8,0,0" />
            <TextBox x:Name="NoteBox" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Скасувати" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}" Width="100" />
            <Button Content="Зберегти" Click="Save_Click" Width="100" />
        </StackPanel>
    </Grid>
</Window>
